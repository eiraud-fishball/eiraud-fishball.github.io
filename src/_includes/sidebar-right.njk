{# ================================================================
   Sidebar Right (Template Layer - Component)
   TOC, page pagination, site stats, categories, tag cloud.
   Magazine-style: text-only section headers with accent underlines.
   ================================================================ #}
<aside class="right-sidebar">
  <!-- Table of Contents -->
  <div class="sidebar-card toc-card" id="tocCard" style="display:none;">
    <h3 class="sidebar-card__title">目录</h3>
    <nav class="toc" id="toc"></nav>
  </div>

  <!-- Site Stats -->
  <div class="sidebar-card site-info-card">
    <h3 class="sidebar-card__title">站点统计</h3>
    <div class="site-info-card__stats">
      <div class="site-info-card__stat">
        <span class="site-info-card__stat-value">{{ collections.posts.length }}</span>
        <span class="site-info-card__stat-label">文章</span>
      </div>
      <div class="site-info-card__stat">
        <span class="site-info-card__stat-value">{{ collections.categories.length }}</span>
        <span class="site-info-card__stat-label">分类</span>
      </div>
      <div class="site-info-card__stat">
        <span class="site-info-card__stat-value">{{ collections.tagList.length }}</span>
        <span class="site-info-card__stat-label">标签</span>
      </div>
      <div class="site-info-card__stat">
        <span class="site-info-card__stat-value">丙午马年</span>
        <span class="site-info-card__stat-label">建站</span>
      </div>
    </div>
  </div>

  <!-- Categories -->
  {% if sidebarCategories and sidebarCategories.length %}
  <div class="sidebar-card categories-card">
    <h3 class="sidebar-card__title">分类</h3>
    <ul class="categories-list">
      {% for cat in sidebarCategories %}
        <li class="categories-list__item">
          <a href="/categories/{{ cat.slug }}/">{{ cat.name }}<span class="categories-list__count">{{ cat.count }}</span></a>
        </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <!-- Sidebar Tags -->
  {% if sidebarTags and sidebarTags.length %}
  <div class="sidebar-card tags-card">
    <h3 class="sidebar-card__title">标签</h3>
    <div class="sidebar-tags">
      {% for tag in sidebarTags | limit(12) %}
        <a href="/tags/{{ tag.slug }}/" class="sidebar-tags__item" data-count="{{ tag.count }}">{{ tag.name }}</a>
      {% endfor %}
    </div>
  </div>
  {% endif %}
</aside>
